<%-include('../partial/head') %>
</head>
<body>
  <%- include('../partial/nav') %>
  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
  <h1 class="text-3xl text-red-500 font-bold text-center mb-6">Home LIst Are Here</h1>
  
  </main>
 
      <div class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-4xl">
        <!-- Image Gallery -->
        <div class="grid grid-cols-2 gap-4 mb-8">
          <img src="<%= home.photo %> " class="col-span-2 h-96 object-cover rounded-lg" >
        </div>

        <!-- Title & Rating -->
        <div class="flex justify-between items-start mb-6 border-b pb-4">
          <div>
            <h1 class="text-4xl font-bold text-gray-800"><%= home.homeName %></h1>
            <p class="text-gray-600 mt-2"><%= home.location %> • <%= home.rating %> ⭐</p>
          </div>
          <p class="text-3xl font-bold text-red-500">$<%= home.price %>/night</p>
        </div>

        <!-- Description & Amenities -->
        <div class="grid grid-cols-3 gap-8 mb-8">
          <div class="col-span-2">
            <h2 class="text-2xl font-bold mb-4">About this place</h2>
            <p class="text-gray-700 mb-6"><%= home.description || 'Beautiful home awaiting your stay.' %></p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <button class="w-full bg-red-500 text-white py-3 rounded-lg font-bold hover:bg-red-600 mb-4">Book Now</button>
          </div>
          
        </div>
        <%-include('../partial/favourate.ejs') %>
     
    </main>
    
    
  </div>
</body>
</html>