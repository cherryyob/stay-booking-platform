<%-include('../partial/head') %>
</head>
<body>
  <%- include('../partial/nav') %>
  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
  <h1 class="text-3xl text-red-500 font-bold text-center mb-6">Favourate Homes Are Here</h1>
  
  </main>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 mx-1">
    <% registorHome.forEach((home) => { %>
      <div class="bg-white rounded-lg mx-1 shadow-lg hover:shadow-xl hover:bg-red-50 transition-colors  duration-200 overflow-hidden border border-gray-300">
      <a href="/home-details/<%=home.id%>">
        <img src="<%= home.photo %>" alt="<%= home.homeName %>" class="w-full h-48 object-cover" loading="lazy">
       </a>
       
          <div class="p-4">
          <h2 class="text-lg font-bold text-gray-800 mb-2"><%= home.homeName %></h2>
          <p class="text-gray-600 text-sm mb-1"><strong></strong> <%= home.location %></p>
          <p class="text-gray-600 text-sm mb-2"><strong></strong> <%= home.rating %> ⭐</p>
          <div class="flex items-center justify-between ">
            <p class="text-red-500 font-bold text-lg"><strong>$<%= home.price %></strong></p>
             <div class="flex items-center justify-between ">
              <form action="/remove-favourate/<%=home.id%>" method="post">
                
                 <button type="submit" class="bg-red-400 rounded-lg py-1 px-4 font-bold hover:bg-red-500 hover:text-lg transition-all inline-block duration-100 ">Remove</button>
             
              </form>
              <button class="bg-red-400 rounded-lg py-1 px-4 font-bold hover:bg-red-500 hover:text-lg transition-all inline-block duration-100 ml-2">Book</button>
            </div>
          </div>
        
          
        </div>
      </div>
    <% }) %>
  </div>
</body>
</html>